# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ------------------------------------------------------------------------------
# Anthropic API — used only for handwriting OCR (scripts/ocr_journals.py).
# Get your key at https://console.anthropic.com
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------------------------
# Personal glossary — names and abbreviations used in your journals.
# Injected into the LLM system prompt so personal names resolve correctly.
# Keep as a single line. Edit freely — no code changes needed.
# ------------------------------------------------------------------------------
JOURNAL_GLOSSARY=People: <name> = <relation>. Work: <abbreviation> = <meaning>. Places: <short> = <full name>.

# ------------------------------------------------------------------------------
# Optional: override the full LLM system prompt.
# If omitted, a prompt is auto-built from JOURNAL_GLOSSARY above.
# ------------------------------------------------------------------------------
# JOURNAL_SYSTEM_PROMPT=You are a personal memory assistant...
